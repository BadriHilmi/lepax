// firestore.rules
// Deploy with: firebase deploy --only firestore:rules
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: authenticated users can read any profile; only owner can write
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId;
    }

    // Plans: authenticated users can read; only host can delete
    match /plans/{planId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.hostId == request.auth.uid;
      allow update: if request.auth != null; // likes, forks, joins
      allow delete: if request.auth.uid == resource.data.hostId;
    }

    // Nudges: sender can create; recipient can read and update (mark read)
    match /nudges/{nudgeId} {
      allow create: if request.auth != null
        && request.resource.data.fromUid == request.auth.uid;
      allow read, update: if request.auth != null
        && (resource.data.toUid == request.auth.uid
          || resource.data.fromUid == request.auth.uid);
    }

    // Friend requests: sender can create; both parties can read/update
    match /friendRequests/{reqId} {
      allow create: if request.auth != null
        && request.resource.data.fromUid == request.auth.uid;
      allow read, update: if request.auth != null
        && (resource.data.toUid == request.auth.uid
          || resource.data.fromUid == request.auth.uid);
    }
  }
}
